RewriteEngine On

# Canonical: no trailing index.html
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Clean routes
RewriteRule ^tentang/?$ /tentang/index.html [L]
RewriteRule ^layanan/?$ /layanan/index.html [L]
RewriteRule ^layanan/detail/?$ /layanan/detail/index.html [L]
RewriteRule ^layanan/hydrant/?$ /layanan/hydrant/index.html [L]
RewriteRule ^layanan/ducting/?$ /layanan/ducting/index.html [L]
RewriteRule ^layanan/sprinkler/?$ /layanan/sprinkler/index.html [L]
RewriteRule ^layanan/([a-z0-9-]+)/?$ /layanan/detail/index.html?slug=$1 [L,QSA,NC]
RewriteRule ^proyek/?$ /proyek/index.html [L]
RewriteRule ^proyek/detail/?$ /proyek/detail/index.php [L]
RewriteRule ^produk/?$ /produk/index.html [L]
RewriteRule ^produk/detail/?$ /produk/detail/index.html [L]
RewriteRule ^artikel-detail/?$ /artikel-detail/index.php [L,QSA]
RewriteRule ^kontak/?$ /kontak/index.html [L]

# Legacy html pages to clean URLs
Redirect 301 /about.html /tentang/
Redirect 301 /service.html /layanan/
Redirect 301 /project-three-column.html /proyek/
Redirect 301 /contact.html /kontak/
Redirect 301 /shop /produk/
Redirect 301 /shop.html /produk/

# Blogger old path redirects
Redirect 301 /2023/01/mesin-amplas.html /proyek/
Redirect 301 /2023/01/heat-exchanger.html /proyek/
Redirect 301 /2023/01/blog-post_16.html /proyek/
Redirect 301 /2023/01/blog-post.html /layanan/instalasi-dryer-receiver-tank/
Redirect 301 /2020/03/company-profile.html /tentang/
Redirect 301 /2020/03/company-exeriences.html /tentang/pengalaman/
Redirect 301 /2018/04/ducting.html /layanan/ducting/
Redirect 301 /2018/04/hydrant.html /layanan/hydrant/

# Custom 404
ErrorDocument 404 /404.html



